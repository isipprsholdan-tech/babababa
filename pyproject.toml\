[project]
name = "babababa"
version = "0.1.0"
description = "A simple greeting app"
authors = [{name = "Polina"}]
license = {text = "MIT"}
readme = "README.md"
requires-python = ">=3.8"

[project.scripts]
VD-games = "VD_games.VD_main:main"

[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[tool.hatch.build.targets.wheel]
packages = ["VD_games"]
